# Copy this file to .env and fill in your keys.
# For testnet keys, register at https://testnet.binancefuture.com
BINANCE_API_KEY=your_api_key_here
BINANCE_SECRET_KEY=your_secret_key_here

# Telegram notifications (optional — see docs/VPS_SETUP.md for a walkthrough).
# Create a bot with @BotFather to get the token; message the bot once, then
# open https://api.telegram.org/bot<TOKEN>/getUpdates to find your chat id.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
